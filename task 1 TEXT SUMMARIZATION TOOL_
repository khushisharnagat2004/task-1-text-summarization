{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyOoqfqv+r6K0Xw0/dqSq3nE"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":null,"metadata":{"id":"2YoqurfvIGn5"},"outputs":[],"source":[]},{"cell_type":"code","source":["# ==============================\n","# TEXT SUMMARIZATION TOOL\n","# User Provides Text\n","# ==============================\n","\n","# Install library first:\n","# pip install nltk\n","\n","import nltk\n","from nltk.corpus import stopwords\n","from nltk.tokenize import sent_tokenize, word_tokenize\n","from collections import defaultdict\n","import string\n","\n","# Download required files\n","nltk.download('punkt')\n","nltk.download('stopwords')\n","nltk.download('punkt_tab') # Added this line to download the missing resource\n","\n","# Function for summarization\n","def summarize_text(text, num_sentences=2):\n","\n","    stop_words = set(stopwords.words(\"english\"))\n","    words = word_tokenize(text.lower())\n","\n","    # Calculate word frequency\n","    word_freq = defaultdict(int)\n","\n","    for word in words:\n","        if word not in stop_words and word not in string.punctuation:\n","            word_freq[word] += 1\n","\n","    # Split text into sentences\n","    sentences = sent_tokenize(text)\n","\n","    # Score sentences\n","    sentence_scores = defaultdict(int)\n","\n","    for sentence in sentences:\n","        for word in word_tokenize(sentence.lower()):\n","            if word in word_freq:\n","                sentence_scores[sentence] += word_freq[word]\n","\n","    # Select top sentences\n","    summarized_sentences = sorted(\n","        sentence_scores,\n","        key=sentence_scores.get,\n","        reverse=True\n","    )[:num_sentences]\n","\n","    # Final summary\n","    summary = \" \".join(summarized_sentences)\n","\n","    return summary\n","\n","\n","# ==============================\n","# Main Program\n","# ==============================\n","\n","while True:\n","\n","    print(\"\\nEnter your text:\")\n","    user_text = input()\n","\n","    summary = summarize_text(user_text)\n","\n","    print(\"\\nSummary:\")\n","    print(summary)\n","\n","    # Ask user to continue\n","    choice = input(\"\\nDo you want to summarize another text? (yes/no): \")\n","\n","    if choice.lower() != \"yes\":\n","        print(\"\\nThank You!\")\n","        break"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Rp2Yr__XmcD3","executionInfo":{"status":"ok","timestamp":1778655532241,"user_tz":-330,"elapsed":58109,"user":{"displayName":"Khushi Sharnagat","userId":"01754248704709198008"}},"outputId":"f460f636-6edd-4554-a311-ea24772a9b20"},"execution_count":1,"outputs":[{"output_type":"stream","name":"stderr","text":["[nltk_data] Downloading package punkt to /root/nltk_data...\n","[nltk_data]   Unzipping tokenizers/punkt.zip.\n","[nltk_data] Downloading package stopwords to /root/nltk_data...\n","[nltk_data]   Unzipping corpora/stopwords.zip.\n","[nltk_data] Downloading package punkt_tab to /root/nltk_data...\n","[nltk_data]   Unzipping tokenizers/punkt_tab.zip.\n"]},{"output_type":"stream","name":"stdout","text":["\n","Enter your text:\n","The sun had only just begun to rise above the distant hills when the town slowly awakened from its silence. Streets that had been empty only moments before were now filling with the soft sounds of footsteps, bicycle bells, and the occasional barking dog echoing through the cool morning air.\n","\n","Summary:\n","Streets that had been empty only moments before were now filling with the soft sounds of footsteps, bicycle bells, and the occasional barking dog echoing through the cool morning air. The sun had only just begun to rise above the distant hills when the town slowly awakened from its silence.\n","\n","Do you want to summarize another text? (yes/no): no\n","\n","Thank You!\n"]}]}]}